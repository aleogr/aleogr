{
  "name": "go:1-bookworm",
  "image": "mcr.microsoft.com/devcontainers/go:1-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "go.toolsManagement.autoUpdate": true,
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"],
        "go.formatTool": "gofmt",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "[go]": {
          "editor.snippetSuggestions": "none",
          "editor.tabSize": 4,
          "editor.insertSpaces": false
        }
      }
    }
  },

  "postCreateCommand": "go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.59.1 && go mod download",

  "mounts": [
    "source=go-cache,target=/go/pkg/mod,type=volume"
  ],

  "remoteUser": "vscode"
}
